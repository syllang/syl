#!/usr/bin/env python3
"""Validate Conventional Commit headers and repository scopes."""

from __future__ import annotations

import os
import re
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path, PurePosixPath


HEADER_RE = re.compile(
    r"^(?P<type>[a-z][a-z0-9-]*)"
    r"\((?P<scope>[A-Za-z0-9._/-]+)\)"
    r"(?P<breaking>!)?: "
    r"(?P<subject>.+)$"
)


@dataclass(frozen=True)
class ScopeTarget:
    name: str
    path: str
    kind: str

    def covers(self, changed_path: str) -> bool:
        if self.path == ".":
            return True
        return changed_path == self.path or changed_path.startswith(f"{self.path}/")


def main() -> int:
    message_path = Path(sys.argv[1])
    subject = message_path.read_text(encoding="utf-8").splitlines()[0]
    repo = repo_root()

    match = HEADER_RE.fullmatch(subject)
    if match is None:
        fail(
            "invalid commit message",
            "",
            "Expected Conventional Commit format with a required scope:",
            "  type(scope): subject",
            "  type(scope)!: subject",
            "",
            "Examples:",
            "  feat(syl_span): add source spans",
            "  chore(.github): update issue templates",
        )

    scope = match.group("scope")
    if has_invalid_scope_syntax(scope):
        fail(
            f"invalid commit scope: {scope}",
            'Do not use empty, absolute, "..", "crates", or "crates/..." scopes.',
        )

    target = resolve_scope(repo, scope)
    if target is None:
        fail(
            f"invalid commit scope: {scope}",
            "Scope must be one of:",
            "  - a package name from crates/*/Cargo.toml",
            "  - an existing non-ignored root-relative path",
            "  - . for repository-wide changes",
            "",
            'Do not use "crates" or "crates/..." as the scope. Use the package name instead.',
        )

    changed_paths = staged_paths(repo)
    if changed_paths and not all(target.covers(path) for path in changed_paths):
        uncovered = [path for path in changed_paths if not target.covers(path)]
        fail(
            f"scope {scope!r} does not cover all staged paths",
            f"Resolved scope target: {target.path} ({target.kind})",
            "",
            "Uncovered staged paths:",
            *[f"  - {path}" for path in uncovered],
            "",
            "Split unrelated changes into separate commits, or use their common root path as the scope.",
            'Use "." only for repository-wide changes.',
        )

    return 0


def repo_root() -> Path:
    result = run_git("rev-parse", "--show-toplevel")
    return Path(result.stdout.strip())


def resolve_scope(repo: Path, scope: str) -> ScopeTarget | None:
    if scope == ".":
        return ScopeTarget(name=scope, path=".", kind="repository root")

    crate_paths = package_paths(repo)
    if scope in crate_paths:
        return ScopeTarget(name=scope, path=crate_paths[scope], kind="crate package")

    scope_path = repo / scope
    if scope_path.exists() and not is_ignored(repo, scope):
        return ScopeTarget(name=scope, path=scope, kind="root path")

    return None


def package_paths(repo: Path) -> dict[str, str]:
    crates_root = repo / "crates"
    if not crates_root.is_dir():
        return {}

    packages: dict[str, str] = {}
    for manifest in sorted(crates_root.glob("*/Cargo.toml")):
        package_name = parse_package_name(manifest)
        if package_name is not None:
            packages[package_name] = posix_relpath(manifest.parent, repo)
    return packages


def parse_package_name(manifest: Path) -> str | None:
    in_package = False
    for raw_line in manifest.read_text(encoding="utf-8").splitlines():
        line = raw_line.split("#", 1)[0].strip()
        if line == "[package]":
            in_package = True
            continue
        if line.startswith("[") and line.endswith("]"):
            in_package = False
            continue
        if not in_package:
            continue
        match = re.fullmatch(r'name\s*=\s*"([^"]+)"', line)
        if match is not None:
            return match.group(1)
    return None


def staged_paths(repo: Path) -> list[str]:
    result = run_git("diff", "--cached", "--name-only", "-z", cwd=repo)
    if not result.stdout:
        return []
    return [path for path in result.stdout.split("\0") if path]


def has_invalid_scope_syntax(scope: str) -> bool:
    if scope in {"", "crates"} or scope.startswith("crates/"):
        return True
    if scope.startswith("/") or "//" in scope:
        return True
    parts = PurePosixPath(scope).parts
    return any(part == ".." for part in parts)


def is_ignored(repo: Path, path: str) -> bool:
    result = subprocess.run(
        ["git", "-C", os.fspath(repo), "check-ignore", "-q", "--", path],
        check=False,
    )
    return result.returncode == 0


def posix_relpath(path: Path, repo: Path) -> str:
    return path.relative_to(repo).as_posix()


def run_git(*args: str, cwd: Path | None = None) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["git", *args],
        cwd=os.fspath(cwd) if cwd is not None else None,
        check=True,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def fail(*lines: str) -> None:
    print("\n".join(lines), file=sys.stderr)
    raise SystemExit(1)


if __name__ == "__main__":
    raise SystemExit(main())
